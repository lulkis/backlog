<!DOCTYPE html>
<html>
<head>
    <title>New List</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/pages/lists.css' />
</head>
<body>
<a class="navigation-box top-left shadow click-anim" href="/">
    <img src="/images/icons/back_arrow.png" width="100%">
</a>

<main>
    <div class="container">
        <div class="list-header" style="background-color: <%= list.color%>">
            <h1><%= list.name%></h1>

            <div class="grd-two">
                <p><%= list.description%></p>
                <div class="grd-options">

                    <a href="/editlist/<%= list.id%>">
                        <div class="navigation-box shadow click-anim">
                            <img src="/images/icons/edit.png" height="30px">
                        </div>
                    </a>

                    <a onclick="list_remove(<%= list.id%>)">
                        <div class="navigation-box shadow click-anim">
                            <img src="/images/icons/delete.png" height="30px">
                        </div>
                    </a>

                </div>
            </div>
        </div>

        <div class="grd-lists">
            <% for(var i = 0; i < content.length; i++) { %>
                <div onclick="goToDetail(event, '/<%= content[i].type %>/detail/<%= content[i].id %>')">
                    <div class="list-image shadow click-anim"
                         style="background-image: url(/images/<%=content[i].type%>/<%= content[i].name.toLowerCase()
                                 .replaceAll(" ", "_")
                                 .replaceAll(":", "")
                                 .replaceAll("'", "")
                                 .replaceAll("´", "")  %>.jpg);">
                        <a class="delete-button shadow" href="/api/remove/<%= list.id%>/<%= content[i].id%>">
                            <img src="/images/icons/delete.png">
                        </a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</main>

<div class="footer">
    <img src="/images/icons/orchid_heart_red.png" height="50px">
</div>
<script src="/javascripts/lists.js"></script>
</body>
</html>
