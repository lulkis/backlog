<!DOCTYPE html>
<html>
<head>
    <title>New List</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/form-style.css' />
    <link rel='stylesheet' href='/stylesheets/color-style.css' />
    <link rel='stylesheet' href='/stylesheets/detail-style.css' />
</head>
<body>
<a class="outer shadow click-anim" href="/">
    <img src="/images/icons/back_arrow.png" width="100%">
</a>

<main>
    <div class="container">
        <h1><%= list.name%></h1>

        <div class="two-grid">
            <p><%= list.description%></p>
            <div class="base">

                <a onclick="list_remove(<%= list.id%>)">
                    <div class="detail-button shadow click-anim">
                        <img src="/images/icons/delete.png" height="30px">
                    </div>
                </a>

                <a href="/editlist/<%= list.id%>">
                    <div class="detail-button shadow click-anim">
                        <img src="/images/icons/edit.png" height="30px">
                    </div>
                </a>
            </div>
        </div>
        <hr>

        <div class="list-grid">
            <% for(var i = 0; i < content.length; i++) { %>
                <div class="list-image shadow click-anim"
                     style="background-image: url(/images/<%=content[i].type%>/<%= content[i].name.toLowerCase()
                        .replaceAll(" ", "_")
                        .replaceAll(":", "")
                        .replaceAll("'", "")
                        .replaceAll("´", "")  %>.jpg);">
                </div>
            <% } %>
        </div>
    </div>
</main>

<div class="footer">
    <img src="/images/icons/orchid_heart_red.png" height="50px">
</div>
<script src="/javascripts/lists.js"></script>
</body>
</html>
