<!DOCTYPE html>
<html>
<head>
    <title><%= media.name%></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/pages/media.css' />
</head>

<body>
    <%if(route === 'book' || route === 'manga'){%>
    <div class="header-img"
         style="background-image: url(/images/<%=route%>/<%= media.name.toLowerCase()
                 .replaceAll(" ", "_")
                 .replaceAll(":", "")
                 .replaceAll("'", "")
                 .replaceAll("´", "")  %>.jpg);">
        <div class="header-gradient"></div>
    </div>
    <%} else {%>
    <div class="header-img"
         style="background-image: url(/images/<%=route%>/header/<%= media.name.toLowerCase()
                 .replaceAll(" ", "_")
                 .replaceAll(":", "")
                 .replaceAll("'", "")
                 .replaceAll("´", "")  %>.jpg);
                 background-position: 0 <%=media.header_space%>%;">
        <div class="header-gradient"></div>
    </div>
    <%}%>

    <a class="navigation-box top-left shadow click-anim" href="/<%= route%>">
        <img src="/images/icons/back_arrow.png" width="100%">
    </a>

    <div class="container">
        <div class="grd-two">
            <div>
                <h1><%= media.name%></h1>
                <div>
                    <% if( route === 'book'){%>
                        <h4>By <a href="/get/<%= media.author%>"><%= media.author%></a></h4>
                    <%}%>
                    <% if( route === 'manga'){%>
                        <h4>By <a href="/get/<%= media.mangaka%>"><%= media.mangaka%></a></h4>
                    <%}%>
                    <% if( route === 'movie'){%>
                        <h4>By
                            <% let arr = media.director.split(", ")
                            for(var i=0; i<arr.length; i++){
                            %>
                                <a href="/get/<%= arr[i]%>"><i><%= arr[i]%></i></a><%if(i != arr.length-1){%>,<%}%>
                            <%}%>
                        </h4>
                    <%}%>
                    <% if( route === 'game'){%>
                        <h4>By <a href="/get/<%= media.developer%>"><%= media.developer%></a></h4>
                    <%}%>
                    <% if( route === 'series'){%>
                        <h4>By
                            <% let arr = media.idea.split(", ")
                                for(var i=0; i<arr.length; i++){
                            %>
                                <a href="/get/<%= arr[i]%>"><i><%= arr[i]%></i></a><%if(i != arr.length-1){%>,<%}%>
                            <%}%>
                        </h4>
                    <%}%>
                </div>
            </div>

            <div class="grd-options">
                <%if((media.status != 'finished' &&  route === 'movie') || media.status === 'started' &&  route != 'movie'){%>
                    <div class="boxtohover">
                        <a href="/<%= route%>/finish/<%= media.id%>" >
                            <div class="navigation-box shadow click-anim">
                                <img src="/images/icons/finish.png" height="30px">
                            </div>
                        </a>
                        <span class="infotohover">Finish Media</span>
                    </div>
                <%}%>

                <%if(media.status === 'open' && route != 'movie'){%>
                <div class="boxtohover">
                    <a href="/<%= route%>/start/<%= media.id%>" >
                        <div class="navigation-box shadow click-anim">
                            <img src="/images/icons/start.png" height="30px">
                        </div>
                    </a>
                    <span class="infotohover">Start Media</span>
                </div>
                <%}%>

                <%if(media.status === 'finished' && route == 'series'){%>
                    <%if(media.year_end === 0){%>
                        <div class="boxtohover">
                            <a href="/<%= route%>/new/<%= media.id%>" >
                                <div class="navigation-box shadow click-anim">
                                    <img src="/images/icons/bolt.png" height="30px">
                                </div>
                            </a>
                            <span class="infotohover">New Season</span>
                        </div>
                    <%}%>
                <%}%>

                <%if(media.status === 'finished'){%>
                    <div class="boxtohover repeat-a">
                        <a href="/<%= route%>/repeat/<%= media.id%>">
                            <div class="navigation-box shadow click-anim">
                                <img src="/images/icons/repeat.png" height="30px">
                                <span class="repeat"><%= finish.finishcount%></span>
                            </div>
                        </a>
                        <span class="infotohover">Finished Again</span>
                    </div>
                <%}%>

                <div class="boxtohover">
                    <a href="/<%=route%>/edit/<%= media.id%>">
                        <div class="navigation-box shadow click-anim">
                            <img src="/images/icons/edit.png" height="30px">
                        </div>
                    </a>
                    <span class="infotohover">Edit Media</span>
                </div>

                <div class="boxtohover">
                    <a id="listbtn" onclick="list_toggle(<%= media.id%>, '<%= route%>')">
                        <div class="navigation-box shadow click-anim">
                            <img src="/images/icons/add.png" height="30px">
                        </div>
                    </a>
                    <div class="list-menu" id="list-menu" style="display: none;">
                    </div>
                    <span class="infotohover">Add to List</span>
                </div>
            </div>
        </div>

        <hr>
        <%if(days > 0){%>
            <div class="upcoming">
                <%
                    const [year, month, day] = media.upcoming.split("-");
                    const showDate = day + '.' + month + '.' + year;
                %>
                <b><%= days%></b> <i>days until release</i> - <%= showDate%>
            </div>
        <%}%>

        <div class="grd-three">
            <div>
                <div class="cncl-image">
                    <img class="media-cover shadow" height="500px" src="/images/<%= route%>/<%= media.name.toLowerCase()
                            .replaceAll(" ", "_")
                            .replaceAll(":", "")
                            .replaceAll("'", "")
                            .replaceAll("´", "")%>.jpg" alt="<%=media.name%>">

                    <%if(route === "series"){%>
                        <%if(media.cancelled === 1){%>
                            <img class="cncl" height="500px" src="/images/icons/cancelled.png">
                        <%}%>
                    <%}%>
                </div>
            </div>

            <div>
                <h1>
                    <%if(media.year > 0){%>
                        <%= media.year %>
                    <%} else {%>
                        <%= Math.abs(media.year)  %> v. Chr.
                    <%}%>

                    <%if(route === 'series' || route === 'manga'){%>
                        <%if(media.year !== media.year_end){%>
                        -
                            <%if(media.year_end === 0){%>
                                <%= "Now" %>
                            <%} else {%>
                                <%= media.year_end %>
                            <%}%>
                        <%}%>
                    <%}%>
                </h1>

                <span>
                    <img src="/images/countries/<%= media.country %>.png" height="35px">
                </span><br>

                <% if(route === 'movie') {%>
                    <p class="minutes">
                        <%if(settings.time_in_minutes === true){%>
                            <%= media.length %> Minutes
                        <%} else {%>
                                <%= (media.length - (media.length%60))/60 %>h <%= (media.length % 60) %>min
                        <%}%>
                    </p>

                    <p>
                        <img src="/images/studios/<%= media.studio %>.png" height="55px" alt="<%= media.studio %>">
                    </p>

                <span><b>Score: </b>
                    <% let arr = media.score.split(", ")
                    for(var i=0; i<arr.length; i++){
                    %>
                        <a class="l-color" href="/get/<%= arr[i]%>"><%= arr[i]%></a><%if(i != arr.length-1){%>,<%}%>
                    <%}%>
                </span><br>

                <%}%>
                <% if(route === 'series') {%>
                    <p>
                        <span><b>Studio:</b> <%= media.studio %></span><br>
                        <span><b>Score: </b>
                            <% let arr = media.score.split(", ")
                            for(var i=0; i<arr.length; i++){
                            %>
                                <a class="l-color" href="/get/<%= arr[i]%>"><%= arr[i]%></a><%if(i != arr.length-1){%>,<%}%>
                            <%}%>
                        </span><br>
                    </p>
                <%}%>

                <% if(route === 'game') {%>
                    <p>
                        <span><b>Publisher:</b> <%= media.publisher %></span><br>
                        <span><b>Score: </b>
                            <% let arr = media.score.split(", ")
                            for(var i=0; i<arr.length; i++){
                            %>
                                <a class="l-color" href="/get/<%= arr[i]%>"><%= arr[i]%></a><%if(i != arr.length-1){%>,<%}%>
                            <%}%>
                        </span><br>
                    </p>
                <%}%>

                <% if(route === 'book') {%>
                    <p>
                        <span><b>Length:</b> <%= media.length %></span><br>
                        <span><b>Publisher:</b> <%= media.publisher %></span><br>
                        <span><b>Illustrator:</b> <%= media.illustrator %></span>
                    </p>
                <%}%>

                <% if(route === 'manga') {%>
                    <p>
                        <span><b>Chapter:</b> <%= media.length %></span><br>
                        <span><b>Publisher:</b> <%= media.publisher %></span><br>
                    </p>
                <%}%>

                <%if(route === 'game'){%>
                    <%if(hltb){%>
                        <div class="hltb-box shadow">
                            <div class="hltb-grid">
                                <div>
                                    <b>Main</b>
                                    <br><%= hltb.main%>h
                                </div>
                                <div>
                                    <b>Main+Extra</b>
                                    <br><%= hltb.main_extra%>h
                                </div>
                                <div>
                                    <b>Completionist</b>
                                    <br><%= hltb.completionist%>h
                                </div>
                            </div>
                        </div>
                    <%}%>
                <%}%>

                <%if(route === 'movie' && stream){%>
                    <p>
                        <div class="stream-box">
                            <%for(var i = 0; i < stream.length; i++){%>
                                <img class="streaming-service shadow" src="https://image.tmdb.org/t/p/w92/<%= stream[i].logo_path%>">
                            <%}%>
                        </div>
                    </p>
                <%}%>

                <p style="margin-top:21px">
                    <% var tiles = media.genre.split(", "); for(var i = 0; i < tiles.length; i++) {%>
                    <span class="tag shadow"><%=tiles[i]%></span>
                    <%}%>
                </p>


                <%if (media.owned !== 'No' && media.owned !== 'no') {%>
                    <div class="owned shadow" style="margin-top:41px">
                        <h5 class="owned-title">In Personal Library as:</h5>
                        <span><%= media.owned %></span>
                    </div>
                <%}%>
            </div>
        </div>

        <%if (media.status === 'started' && (route === 'book' || route === 'manga')) {%>
        <hr>
        <div>
            <h3>Progress</h3>
            <p><span id="progress">0</span>/<%= media.length%></p>
            <input style="width: 100%" type="range" min="1" max="<%=media.length%>" value="<%= progress%>" class="slider" id="myRange">

            <div class="progress-box">
                <a id="progressLink" href="#" class="progress-link shadow click-anim">
                    Save Progress
                </a>
            </div>

            <script>
                const range = document.getElementById("myRange");
                const progress = document.getElementById("progress");
                const link = document.getElementById("progressLink");

                function updateProgress() {
                    progress.innerHTML = range.value;

                    link.href = "/<%= route%>/progress/<%= media.id %>/" + range.value;
                }

                range.addEventListener("input", updateProgress);

                updateProgress();
            </script>
        </div>
        <% } %>

        <hr>
        <div>
            <h3>Description</h3>
            <p><%= media.description%></p>
        </div>

        <% if(!(route === 'book') && media.cast) {%>
            <hr>
            <h3>Besetzung</h3>
            <div>
                <% var role = media.cast.split("\n") %>
                <div class="grd-two">
                    <div>
                        <ul>
                            <%for(var i=0; i<role.length; i++) {%>
                            <%if(i%2 === 0){%>
                                <% var actor = role[i].split(':')%>
                                <li class="cast-element">
                                    <a href="/search/<%=actor[0]%>"><b><%=actor[0]%></b></a>:<i><%=actor[1]%></i>
                                </li>
                            <%}%>
                            <%}%>
                        </ul>
                    </div>
                    <div>
                        <ul>
                            <%for(var i=0; i<role.length; i++) {%>
                            <%if(i%2 != 0){%>
                                <% var actor = role[i].split(':')%>
                                <li class="cast-element">
                                    <a href="/search/<%=actor[0]%>"><b><%=actor[0]%></b></a>:<i><%=actor[1]%></i>
                                </li>
                            <%}%>
                            <%}%>
                        </ul>
                    </div>
                </div>
            </div>
        <%}%>

        <% if(route === 'series') {%>
            <hr>
            <div>
                <h3 class="topic-header">Episodes</h3>
                <div  class="episode-box">
                    <% var seasons = media.episodes.split(";")%>
                    <%for(var i = 0; i < seasons.length;i++){%>
                    <div class="season-box">
                        <h5 class="season-header">Staffel <%=(i+1)%></h5>
                        <hr>
                        <ol>
                            <% var episodes = seasons[i].split("\n")%>
                            <% for(var j = 0; j < episodes.length; j++) {%>
                            <li><%=episodes[j]%></li>
                            <%}%>
                        </ol>
                    </div>
                    <%}%>
                </div>
            </div>
        <%}%>

        <%if(media.status === 'finished') {%>
            <hr>
            <div class="finished-box shadow">
                <div class="grd-two">
                    <h3>Review</h3>

                    <a href="/<%= route%>/editval/<%=media.id%>"  class="edit-val">
                        <div class="navigation-box shadow click-anim">
                            <img src="/images/icons/edit.png" height="30px">
                        </div>
                    </a>
                </div>

                <p><%= finish.valuation%></p>
                <p class="rating">
                    <%= finish.rating%>/10
                    <%if(finish.like === "true" || finish.like === 1){%>
                        <img src="/images/icons/heart.png" height="30px">
                    <%}%>
                </p>
            </div>
        <%}%>

        <% if(inlist.length !== 0) {%>
        <hr>
        <h3>Is in List</h3>
        <div class="grd-lists">
            <%for(var i = 0; i < inlist.length; i++) {%>
                <a class="list-box shadow click-anim" href="/list/<%= inlist[i].id %>"
                   style="background-color: <%= inlist[i].color%>">
                    <div><%= inlist[i].name %></div>
                </a>
            <%}%>
        </div>
        <%}%>

    </div>
    <script src="/javascripts/lists.js"></script>

    <div class="footer">
        <img src="/images/icons/orchid_heart_red.png" height="50px">
    </div>
</body>
</html>
