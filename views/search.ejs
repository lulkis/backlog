<!DOCTYPE html>
<html>
<head>
    <title>Search</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/pages/search.css' />
</head>
<body>

<a class="navigation-box top-left shadow click-anim" onclick="history.back()">
    <img src="/images/icons/back_arrow.png" width="100%">
</a>

    <main>
        <div class="container">
            <%if(search_type === "actor"){%>
                <div class="grd-two">
                    <div class="actor-image shadow"
                         style="background-image:url('/images/actors/<%= name.replaceAll(".", "")%>.jpg')"
                    ></div>
                    <h1><%= name%></h1>
                </div>
            <%} else {%>
                <h1><%= name%></h1>
            <%}%>


                <%for(const route in list){%>
                    <div class="media-list">
                        <%if(list[route].length != 0){%>
                        <h3><%= route.toUpperCase() %></h3>
                            <% for (const item of list[route]) { %>
                                <a href="/<%= route%>/detail/<%=item.id%>">
                                    <div class="lines">
                                        <div class="grd-search-element search-element">
                                            <img class="shadow" src="/images/<%= route%>/<%= item.name.toLowerCase()
                                                    .replaceAll(" ", "_")
                                                    .replaceAll(":", "")
                                                    .replaceAll("'", "")
                                                    .replaceAll("´", "")%>.jpg" alt="<%=item.name%>">

                                            <div>
                                                <p>
                                                    <span style="font-size: 20px;"><b><%= item.name%></b></span><br>
                                                    <span>(<%= item.year%>)</span><br>
                                                    <span>By <%= item.maker%></span>
                                                </p>
                                            </div>

                                            <div class="status-box shadow">
                                                <% if(item.status === "open"){%>
                                                    <img src="/images/icons/open.png">
                                                <%} else if(item.status === "started") {%>
                                                    <img src="/images/icons/start.png">
                                                <% } else { %>
                                                    <img src="/images/icons/finish.png">
                                                <%}%>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            <%}%>
                        <%}%>
                    </div>
                <%}%>
        </div>
    </main>

    <div class="footer">
        <img src="/images/icons/orchid_heart_red.png" height="50px">
    </div>
</body>
</html>
