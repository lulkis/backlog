<!DOCTYPE html>
<html>
<head>
    <title>Search</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/color-style.css' />
    <link rel='stylesheet' href='/stylesheets/search-style.css'>
</head>
<body>

<a class="outer shadow search-button click-anim" onclick="history.back()">
    <img src="/images/icons/back_arrow.png" width="100%">
</a>

    <main>
        <div class="container">
            <h1><%= name%></h1>

            <%if(list.length != 0){%>
                <div class="media-list">
                    <h3>Movies</h3>
                    <% for(var i = 0; i < list.length; i++) {%>
                    <a href="/movie/detail/<%=list[i].id%>">
                        <div class="lines">
                            <div class="search-grid">
                                <img class="shadow" src="/images/movie/<%= list[i].name.toLowerCase()
                                        .replaceAll(" ", "_")
                                        .replaceAll(":", "")
                                        .replaceAll("'", "")
                                        .replaceAll("´", "")%>.jpg" alt="<%=list[i].name%>">

                                <div>
                                    <h3 class="media-item"><%= list[i].name%></h3>
                                    <p>by <span style="font-style: italic"><%= list[i].director%></span></p>
                                </div>

                                <div class="status-box shadow">
                                    <% if(list[i].status === "open"){%>
                                        <img src="/images/icons/open.png" width="50px">
                                    <%} else if(list[i].status === "started") {%>
                                        <img src="/images/icons/start.png" width="50px">
                                    <% } else { %>
                                        <img src="/images/icons/finish.png" width="50px">
                                    <%}%>
                                </div>
                            </div>
                        </div>
                    </a>
                    <%}%>
                </div>
            <%}%>

            <%if(list2.length != 0){%>
                <div class="media-list">
                    <h3>Series</h3>
                    <% for(var i = 0; i < list2.length; i++) {%>
                    <a href="/series/detail/<%=list2[i].id%>">
                        <div class="lines">
                            <div class="search-grid">
                                <img class="shadow" src="/images/series/<%= list2[i].name.toLowerCase()
                                        .replaceAll(" ", "_")
                                        .replaceAll(":", "")
                                        .replaceAll("'", "")
                                        .replaceAll("´", "")%>.jpg" alt="<%=list2[i].name%>">

                                <div>
                                    <h3 class="media-item"><%= list2[i].name%></h3>
                                    <p>by <span style="font-style: italic"><%= list2[i].idea%></span></p>
                                </div>

                                <div class="status-box shadow">
                                    <% if(list2[i].status === "open"){%>
                                        <img src="/images/icons/open.png" width="50px">
                                    <%} else if(list2[i].status === "started") {%>
                                        <img src="/images/icons/start.png" width="50px">
                                    <% } else { %>
                                        <img src="/images/icons/finish.png" width="50px">
                                    <%}%>
                                </div>
                            </div>
                        </div>
                    </a>
                    <%}%>
                </div>
            <%}%>

            <%if(list3.length != 0){%>
                <div class="media-list">
                    <h3>Games</h3>
                    <% for(var i = 0; i < list3.length; i++) {%>
                    <a href="/game/detail/<%=list3[i].id%>">
                        <div class="lines">
                            <div class="search-grid">
                                <img class="shadow" src="/images/game/<%= list3[i].name.toLowerCase()
                                        .replaceAll(" ", "_")
                                        .replaceAll(":", "")
                                        .replaceAll("'", "")
                                        .replaceAll("´", "")%>.jpg" alt="<%=list3[i].name%>">

                                <div>
                                    <h3 class="media-item"><%= list3[i].name%></h3>
                                    <p>by <span style="font-style: italic"><%= list3[i].developer%></span></p>
                                </div>

                                <div class="status-box shadow">
                                    <% if(list3[i].status === "open"){%>
                                        <img src="/images/icons/open.png" width="50px">
                                    <%} else if(list3[i].status === "started") {%>
                                        <img src="/images/icons/start.png" width="50px">
                                    <% } else { %>
                                        <img src="/images/icons/finish.png" width="50px">
                                    <%}%>
                                </div>
                            </div>
                        </div>
                    </a>
                    <%}%>
                </div>
            <%}%>

            <%if(list4.length != 0){%>
                <div class="media-list">
                    <h3>Books</h3>
                    <% for(var i = 0; i < list4.length; i++) {%>
                    <a href="/book/detail/<%=list4[i].id%>">
                        <div class="lines">
                            <div class="search-grid">
                                <img class="shadow" src="/images/book/<%= list4[i].name.toLowerCase()
                                        .replaceAll(" ", "_")
                                        .replaceAll(":", "")
                                        .replaceAll("'", "")
                                        .replaceAll("´", "")%>.jpg" alt="<%=list4[i].name%>">

                                <div>
                                    <h3 class="media-item"><%= list4[i].name%></h3>
                                    <p>by <span style="font-style: italic"><%= list4[i].author%></span></p>
                                </div>

                                <div class="status-box shadow">
                                    <% if(list4[i].status === "open"){%>
                                        <img src="/images/icons/open.png" width="50px">
                                    <%} else if(list4[i].status === "started") {%>
                                        <img src="/images/icons/start.png" width="50px">
                                    <% } else { %>
                                        <img src="/images/icons/finish.png" width="50px">
                                    <%}%>
                                </div>
                            </div>
                        </div>
                    </a>
                    <%}%>
                </div>
            <%}%>
        </div>
    </main>

    <div class="footer">
        <img src="/images/icons/orchid_heart_red.png" height="50px">
    </div>
</body>
</html>
